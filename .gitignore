# ── Secrets — NEVER commit ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ──────────────────────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/

# ── Node ────────────────────────────────────────────────────────────────────
node_modules/

# ── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes

